
# ── RICK.AI — n8n Environment Variables ──────────────────────
# Copy these into n8n: Settings > Environment Variables

# X / Twitter API v2
X_API_KEY_RICKAI=                          # From developer.twitter.com
X_API_SECRET_RICKAI=
X_ACCESS_TOKEN_RICKAI=
X_ACCESS_TOKEN_SECRET_RICKAI=

# LinkedIn
LINKEDIN_ACCESS_TOKEN_RICKAI=              # OAuth 2.0 from LinkedIn Developer Portal
LINKEDIN_ORG_ID_RICKAI=                    # Company page ID (or personal profile URN)

# YouTube
YOUTUBE_CLIENT_ID_RICKAI=                  # Google Cloud Console OAuth
YOUTUBE_CLIENT_SECRET_RICKAI=
YOUTUBE_REFRESH_TOKEN_RICKAI=              # Persistent refresh token
YOUTUBE_CHANNEL_ID_RICKAI=

# GitHub (already active — Rickybarton138)
GITHUB_TOKEN_RICKAI=                       # PAT from github.com/settings/tokens

# Anthropic (shared across brands)
ANTHROPIC_API_KEY=                         # From console.anthropic.com

# Airtable CRM
AIRTABLE_BASE_ID_RICKAI=                   # From Airtable URL: airtable.com/appXXXXXX
AIRTABLE_API_TOKEN=                        # From airtable.com/create/tokens

# Brave Search (for trend research)
BRAVE_API_KEY=                             # From brave.com/search/api

# Canva API (social image generation)
CANVA_CLIENT_ID_RICKAI=
CANVA_ACCESS_TOKEN_RICKAI=

# Website
RICKAI_SITE_URL=https://rick.ai
RICKAI_CONTACT_EMAIL=rickybarton138@btinternet.com
